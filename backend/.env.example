# 应用
APP_NAME=LakeSea Digital Twin
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# 数据库：本地开发默认 SQLite；生产改为达梦连接串
# SQLite 示例
DATABASE_URL=sqlite:///./lakesea.db
# 达梦 DM8 示例（按实际环境修改）
# DATABASE_URL=dm+dmPython://SYSDBA:password@localhost:5236/LAKESEA

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DeepSeek AI（Phase 4）
# MOCK_AI=true 时使用本地模拟报告，无需 API Key
MOCK_AI=true
# DEEPSEEK_API_KEY=your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# 试验文件上传目录
UPLOAD_DIR=uploads
