# 应用
APP_NAME=LakeSea Digital Twin
DEBUG=true
SECRET_KEY=change-me-in-production-use-long-random-string

# 数据库：本地开发默认 SQLite；生产改为达梦连接串
# SQLite 示例
DATABASE_URL=sqlite:///./lakesea.db
# 达梦 DM8 示例（按实际环境修改）
# DATABASE_URL=dm+dmPython://SYSDBA:password@localhost:5236/LAKESEA

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS（前端开发地址）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# DeepSeek（后续 Phase 4 使用）
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
