# 达梦 DM8 生产/答辩环境配置示例
# 用法：copy .env.dm8.example .env  然后按实际环境修改

APP_NAME=LakeSea Digital Twin
DEBUG=false
SECRET_KEY=change-me-in-production-use-long-random-string

# 达梦 DM8 连接串（按实际主机、端口、用户、库名修改）
# 格式：dm+dmPython://用户名:密码@主机:端口/库名或模式名
DATABASE_URL=dm+dmPython://SYSDBA:YourPassword@localhost:5236/LAKESEA

JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI：答辩有 Key 时设 MOCK_AI=false 并填写 DEEPSEEK_API_KEY
MOCK_AI=true
# DEEPSEEK_API_KEY=your-key-here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

UPLOAD_DIR=uploads
